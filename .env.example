# ======================
# SPRING PROFILE
# ======================
# Opciones: dev, test, prod
SPRING_PROFILE=dev

# ======================
# DATABASE CONFIG - SUPABASE (Transaction Pooler - IPv4 compatible)
# ======================
# MS-AUTH - URL del Transaction Pooler de Supabase (compatible con IPv4)
# Reemplaza con tu URL de Transaction Pooler de Supabase
DB_URL=jdbc:postgresql://aws-1-us-west-2.pooler.supabase.com:6543/postgres?sslmode=require&prepareThreshold=0
DB_USER=postgres.[TU-PROJECT-REF]
DB_PASSWORD=[TU-CONTRASEÑA-DE-SUPABASE]

# MS-CATALOG
# DB_URL_CATALOG=jdbc:postgresql://db.xxx.supabase.co:5432/postgres?sslmode=require
# DB_USER_CATALOG=postgres.your-project-ref-catalog
# DB_PASSWORD_CATALOG=tu-contraseña-segura

# ======================
# JWT CONFIG (MISMO VALOR EN TODOS LOS MS)
# ======================
# Genera un token seguro con: openssl rand -base64 64
JWT_SECRET=[TU-JWT-SECRET-SEGURA]
JWT_EXPIRATION=86400000

# ======================
# EMAIL CONFIG (Gmail SMTP)
# ======================
# Para usar Gmail SMTP, debes generar un App Password en tu cuenta de Google
# Ve a: https://myaccount.google.com/apppasswords
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-generated-in-google

# ======================
# FRONTEND URL
# ======================
# URL del frontend para los enlaces de verificación de email
FRONTEND_URL=http://localhost:3000

# ======================
# EXTERNAL SERVICES URLs
# ======================
# URLs de los otros microservicios
SERVICES_AUTH_URL=http://localhost:8081
SERVICES_CATALOG_URL=http://localhost:8082
SERVICES_RESOURCE_URL=http://localhost:8083
SERVICES_RESERVATION_URL=http://localhost:8084